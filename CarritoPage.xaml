<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:appP.A.Models"
             x:Class="appP.A.CarritoPage"
             Title="Mi Carrito"
             BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource OffBlack}}">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Vaciar Todo" Priority="0" Order="Primary" Clicked="OnVaciarClicked"/>
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="*, Auto">

        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="15" Spacing="10">

                <VerticalStackLayout x:Name="EmptyState" IsVisible="False" Padding="30" Spacing="10" HorizontalOptions="Center" VerticalOptions="Center">
                    <Label Text="Tu carrito está vacío" FontSize="20" FontAttributes="Bold" HorizontalOptions="Center" TextColor="Gray"/>
                    <Label Text="Agrega productos desde la tienda para verlos aquí." FontSize="14" TextColor="Silver" HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
                    <Button Text="Ir a Comprar" BackgroundColor="{StaticResource Primary}" TextColor="White" CornerRadius="20" Margin="0,15,0,0" Clicked="OnSeguirComprandoClicked" />
                </VerticalStackLayout>

                <CollectionView x:Name="ItemsList" ItemsSource="{Binding Productos}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:Producto">
                            <Frame Padding="12" Margin="0,5" CornerRadius="15" HasShadow="False"
                                   BorderColor="{StaticResource Gray200}"
                                   BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Black}}">

                                <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto">
                                    <Image Source="{Binding Imagen}" HeightRequest="70" WidthRequest="70" Aspect="AspectFit" Grid.RowSpan="2" Margin="0,0,10,0"/>

                                    <Label Grid.Column="1" Grid.Row="0" Text="{Binding Nombre}" FontSize="16" FontAttributes="Bold" VerticalOptions="End"/>
                                    <Label Grid.Column="1" Grid.Row="1" Text="{Binding Precio, StringFormat='${0:F2}'}" FontSize="14" TextColor="Green" VerticalOptions="Start"/>

                                    <VerticalStackLayout Grid.Column="2" Grid.RowSpan="2" VerticalOptions="Center" Spacing="5">
                                        <HorizontalStackLayout Spacing="10" HorizontalOptions="End">
                                            <Button Text="-" WidthRequest="35" HeightRequest="35" Padding="0" 
                                                    BackgroundColor="LightGray" TextColor="Black" FontAttributes="Bold" CornerRadius="17"
                                                    CommandParameter="{Binding .}" Clicked="OnReducirCantidadClicked"/>

                                            <Label Text="{Binding Cantidad}" FontSize="16" FontAttributes="Bold" VerticalOptions="Center"/>

                                            <Button Text="+" WidthRequest="35" HeightRequest="35" Padding="0" 
                                                    BackgroundColor="{StaticResource Primary}" TextColor="White" FontAttributes="Bold" CornerRadius="17"
                                                    CommandParameter="{Binding .}" Clicked="OnAumentarCantidadClicked"/>
                                        </HorizontalStackLayout>

                                        <Button Text="Quitar" BackgroundColor="Transparent" TextColor="DarkRed" FontSize="12" Padding="0" HeightRequest="25"
                                                HorizontalOptions="End" CommandParameter="{Binding .}" Clicked="OnEliminarProductoClicked" />
                                    </VerticalStackLayout>
                                </Grid>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </ScrollView>

        <Frame Grid.Row="1" Padding="20" HasShadow="True" BorderColor="Transparent" CornerRadius="20" Margin="0,-20,0,0"
               BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray950}}">
            <VerticalStackLayout Spacing="15">
                <Grid ColumnDefinitions="*,Auto">
                    <Label Text="Total a pagar:" FontSize="18" TextColor="Gray" VerticalOptions="Center" />
                    <Label Grid.Column="1" Text="{Binding Total, StringFormat='${0:F2}'}" FontSize="24" FontAttributes="Bold" HorizontalOptions="End" TextColor="{StaticResource Primary}" />
                </Grid>

                <Button Text="FINALIZAR COMPRA" BackgroundColor="{StaticResource Primary}" TextColor="White" HeightRequest="55" CornerRadius="25" FontAttributes="Bold" FontSize="16" Clicked="OnCheckoutClicked" />
                <Button Text="Seguir comprando" BackgroundColor="Transparent" TextColor="{StaticResource Primary}" FontAttributes="Bold" Clicked="OnSeguirComprandoClicked" />
            </VerticalStackLayout>
        </Frame>
    </Grid>
</ContentPage>
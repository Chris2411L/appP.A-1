<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="appP.A.MainPage"
             Title="NONTONIO">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="🛒 Carrito" Clicked="OnVerCarritoClicked" />
        <ToolbarItem Text="👤 Perfil" Clicked="OnVerPerfilClicked" />
    </ContentPage.ToolbarItems>

    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#1A0A2A" Offset="0.1" />
            <GradientStop Color="#2E1A4A" Offset="1.0" />
        </LinearGradientBrush>
    </ContentPage.Background>

    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <Frame BackgroundColor="#8A2BE2" CornerRadius="0" Padding="25" HasShadow="False" BorderColor="Transparent">
                <VerticalStackLayout Spacing="5" HorizontalOptions="Center">
                    <Label x:Name="WelcomeLabel" Text="¡Hola!" FontSize="28" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center"/>
                    <Label Text="¿Qué se te antoja hoy?" FontSize="16" TextColor="WhiteSmoke" HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Frame>

            <VerticalStackLayout Padding="25" Spacing="25">

                <Frame Padding="0" CornerRadius="20" HeightRequest="160" IsClippedToBounds="True" HasShadow="True" BorderColor="Transparent">
                    <Grid>
                        <Image Source="https://img.freepik.com/free-photo/arrangement-with-delicious-candies_23-2149051410.jpg" Aspect="AspectFill"/>
                        <BoxView Color="#AA000000"/>
                        <Label Text="🚀 ENVÍOS GRATIS&#10;en compras mayores a $299" 
                               TextColor="White" FontSize="20" FontAttributes="Bold" 
                               HorizontalOptions="Center" VerticalOptions="Center" 
                               HorizontalTextAlignment="Center"/>
                    </Grid>
                </Frame>

                <Button Text="🔥 ¡EMPEZAR MI ANTOJO!"
                        BackgroundColor="#8A2BE2"
                        TextColor="White"
                        CornerRadius="35"
                        HeightRequest="80"
                        FontSize="22"
                        FontAttributes="Bold"
                        Clicked="OnVerCategoriasClicked"
                        Margin="0,10">
                    <Button.Shadow>
                        <Shadow Brush="Black" Offset="0,10" Radius="10" Opacity="0.4"/>
                    </Button.Shadow>
                </Button>

                <Button x:Name="ChangeUserButton"
                        Text="Cambiar de Usuario"
                        BackgroundColor="#333333"
                        TextColor="White"
                        CornerRadius="25"
                        HeightRequest="50"
                        Clicked="OnChangeUserClicked"
                        IsVisible="False" />

                <VerticalStackLayout x:Name="AdminPanel" Spacing="10" IsVisible="False">
                    <BoxView HeightRequest="1" Color="Gray" Margin="0,10"/>
                    <Label Text="Panel de Administración" TextColor="Gray" HorizontalOptions="Center"/>
                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="15">
                        <Button Text="⚙️ USUARIOS" BackgroundColor="DarkRed" Clicked="OnPanelUsuariosClicked" CornerRadius="10" />
                        <Button Text="📦 ALMACÉN" BackgroundColor="#004D40" Clicked="OnPanelAlmacenClicked" CornerRadius="10" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>

                <Image Source="nontonio.png" HeightRequest="120" HorizontalOptions="Center" Margin="0,20"/>

            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:appP.A.Models"
             x:Class="appP.A.CategoriasPage"
             Title="Categorías"
             BackgroundColor="{AppThemeBinding Light=#F9F9F9, Dark=#121212}">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">
            <Label Text="🍬 ¿Qué se te antoja?" FontSize="24" FontAttributes="Bold" HorizontalOptions="Center" TextColor="{StaticResource Primary}"/>

            <CollectionView x:Name="CategoriasList" SelectionMode="Single" SelectionChanged="OnCategoriaSelected">
                <CollectionView.ItemsLayout>
                    <GridItemsLayout Orientation="Vertical" Span="2" HorizontalItemSpacing="15" VerticalItemSpacing="15"/>
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Categoria">
                        <Frame HeightRequest="160" Padding="0" CornerRadius="20" HasShadow="True" BorderColor="Transparent">
                            <Grid>
                                <BoxView BackgroundColor="#8A2BE2" Opacity="0.9"/>
                                <VerticalStackLayout VerticalOptions="Center" Spacing="10" Padding="10">
                                    <Label Text="📦" FontSize="40" HorizontalOptions="Center"/>
                                    <Label Text="{Binding Nombre}" TextColor="White" FontAttributes="Bold" FontSize="16" HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
                                </VerticalStackLayout>
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="appP.A.LoginPage"
             Title="Bienvenido"
             BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource OffBlack}}">

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="20" VerticalOptions="Center">

            <Image Source="nontonio.png" HeightRequest="150" HorizontalOptions="Center" />

            <Label Text="NONTONIO" 
                   FontSize="28" 
                   FontAttributes="Bold" 
                   TextColor="{StaticResource Primary}"
                   HorizontalOptions="Center" />

            <Label Text="Tu tienda en línea" 
                   FontSize="14" 
                   TextColor="Gray" 
                   HorizontalOptions="Center" />

            <Frame CornerRadius="15" Padding="20" HasShadow="False" 
                   BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Black}}"
                   BorderColor="LightGray">

                <VerticalStackLayout Spacing="15">
                    <Entry x:Name="UsernameEntry" Placeholder="Nombre de usuario" Keyboard="Text" />
                    <Entry x:Name="PasswordEntry" Placeholder="Contraseña" IsPassword="True" />

                    <BoxView HeightRequest="1" Color="LightGray" Margin="0,10" />

                    <Label Text="Seguridad: Resuelve la suma" FontSize="12" TextColor="Gray" />

                    <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                        <Label x:Name="CaptchaLabel" Text="0 + 0 =" VerticalOptions="Center" FontSize="18" FontAttributes="Bold" />
                        <Entry x:Name="CaptchaEntry" Placeholder="?" WidthRequest="60" Keyboard="Numeric" HorizontalTextAlignment="Center" />
                        <Button Text="↻" Clicked="OnRefreshCaptchaClicked" BackgroundColor="Transparent" TextColor="Gray" FontSize="18" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Frame>

            <VerticalStackLayout Spacing="10" Margin="0,10,0,0">
                <Button Text="INGRESAR A LA TIENDA" 
                        Clicked="OnLoginClicked" 
                        FontAttributes="Bold" />

                <Button Text="Crear una cuenta" 
                        Clicked="OnRegisterClicked" 
                        BackgroundColor="Transparent" 
                        TextColor="{StaticResource Primary}" 
                        FontAttributes="Bold" />
            </VerticalStackLayout>

            <Label x:Name="MessageLabel" TextColor="Red" IsVisible="False" HorizontalOptions="Center" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>